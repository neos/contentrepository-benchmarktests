{
    "name": "neos/contentrepository-benchmarktests",
    "type": "neos-package",
    "description": "Benchmark Test Suite for the ES CR",
    "support": {
        "forum": "https://discuss.neos.io/",
        "docs": "https://docs.neos.io/"
    },
    "license": [
        "GPL-3.0-or-later"
    ],
    "scripts": {
        "lint:phpstan": "../../bin/phpstan analyse Classes --level 8"
