        "neos/contentrepository-testsuite": "^9.0",
        "neos/contentrepositoryregistry": "^9.0"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "Neos\\ContentRepository\\BenchmarkTests\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Neos\\ContentRepository\\BenchmarkTests\\Tests\\": "Tests"
        }
